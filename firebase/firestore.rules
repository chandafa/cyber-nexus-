rules_version = '2';

// Koleksi `licenses` HANYA boleh diakses lewat Cloud Functions (Admin SDK,
// yang melewati rules). Klien mana pun DITOLAK total — tidak ada cara membaca
// daftar kode, menebak, atau mengubah status dari sisi klien.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
