# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build output
dist/
src-tauri/target/

# Python runtime yang di-bundle (di-generate scripts/prepare-python-runtime.ps1).
# Folder dipertahankan via PLACEHOLDER.txt agar glob resource Tauri tidak error
# saat build lokal/CI tanpa runtime; isi sebenarnya (python.exe, Lib/, dll.) diabaikan.
python-runtime/*
!python-runtime/PLACEHOLDER.txt

# Runtime data
*.db
*.db-journal
reports/
captures/
/tmp/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Wordlists (large) — keep samples only
wordlists/rockyou_full.txt

# Build/run logs
*.log
build.exit

# Certificates
python/modules/waf_cert.pem
python/modules/waf_key.pem

# Tauri updater signing keys — RAHASIA, jangan pernah commit private key.
# Public key (.pub) boleh ditaruh di tauri.conf.json; private key masuk GitHub Secret.
.tauri-keys/